{
  "info": {
    "name": "GearUp API",
    "description": "Rent Sports & Outdoor Gear Instantly — backend API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://gearup-backend-nine-psi.vercel.app/api" },
    { "key": "token", "value": "" },
    { "key": "providerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "gearItemId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "rentalOrderId", "value": "" },
    { "key": "paymentId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Customer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Customer\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"CUSTOMER\"\n}"
            }
          }
        },
        {
          "name": "Register (Provider)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Provider\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"PROVIDER\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Gear (Public)",
      "item": [
        {
          "name": "Get All Gear",
          "request": { "method": "GET", "url": "{{baseUrl}}/gear?category=Cycling&minPrice=5&maxPrice=50" }
        },
        {
          "name": "Get Gear By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/gear/{{gearItemId}}" }
        },
        {
          "name": "Get All Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        }
      ]
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "Create Rental Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/rentals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-08-01\",\n  \"endDate\": \"2026-08-05\",\n  \"items\": [\n    { \"gearItemId\": \"{{gearItemId}}\", \"quantity\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get My Rentals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/rentals"
          }
        },
        {
          "name": "Get Rental By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/rentals/{{rentalOrderId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Session (SSLCommerz)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/payments/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalOrderId\": \"{{rentalOrderId}}\"\n}"
            }
          }
        },
        {
          "name": "Confirm Payment (callback)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/confirm?transactionId=GEARUP-xxxx&val_id=xxxx"
          }
        },
        {
          "name": "Get My Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments/{{paymentId}}"
          }
        }
      ]
    },
    {
      "name": "Provider",
      "item": [
        {
          "name": "Add Gear",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/gear",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Trek Mountain Bike\",\n  \"description\": \"All-terrain mountain bike\",\n  \"brand\": \"Trek\",\n  \"pricePerDay\": 15,\n  \"stock\": 5,\n  \"categoryId\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Update Gear",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/gear/{{gearItemId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pricePerDay\": 18,\n  \"stock\": 3\n}"
            }
          }
        },
        {
          "name": "Delete Gear",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": "{{baseUrl}}/provider/gear/{{gearItemId}}"
          }
        },
        {
          "name": "Get Provider Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": "{{baseUrl}}/provider/orders"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/orders/{{rentalOrderId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gearItemId\": \"{{gearItemId}}\",\n  \"rentalOrderId\": \"{{rentalOrderId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great gear, worked perfectly!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gearup.com\",\n  \"password\": \"Admin@12345\"\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SUSPENDED\"\n}"
            }
          }
        },
        {
          "name": "Get All Gear",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/gear"
          }
        },
        {
          "name": "Get All Rentals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/rentals"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Camping\"\n}"
            }
          }
        }
      ]
    }
  ]
}
